{
  "name": "lucidia-workspace",
  "version": "1.0.0",
  "description": "Real-time visualization of BlackRoad OS Agent Workspace (Extended from PixelHQ)",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "lucidia-workspace": "dist/bin/cli.js",
    "pixelhq": "dist/bin/cli.js"
  },
  "files": [
    "dist/",
    "assets/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bin/cli.js",
    "dev": "tsc && node --watch dist/bin/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "blackroad",
    "lucidia",
    "agents",
    "pixel-art",
    "visualization",
    "claude-code",
    "websocket",
    "pixel-office",
    "pixelhq",
    "nats",
    "multi-agent"
  ],
  "author": "BlackRoad OS (Extended from PixelHQ by waynedev9598)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blackboxprogramming/lucidia-workspace.git"
  },
  "homepage": "https://github.com/blackboxprogramming/lucidia-workspace#readme",
  "bugs": "https://github.com/blackboxprogramming/lucidia-workspace/issues",
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "bonjour-service": "^1.2.1",
    "chokidar": "^3.6.0",
    "nats": "^2.29.3",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
